{
  "enabled": {
    "type": "bool",
    "description": "是否启用上下文模板注入。",
    "default": true
  },
  "expand_prompt_placeholders": {
    "type": "bool",
    "description": "是否展开用户提示词中的 {{ctx:alias}} 占位符。",
    "default": true
  },
  "append_aliases": {
    "type": "list",
    "description": "始终追加到 system_prompt 末尾的模板别名列表。",
    "default": []
  },
  "append_separator": {
    "type": "text",
    "description": "追加多个模板时使用的分隔符。",
    "default": "\n\n"
  },
  "missing_behavior": {
    "type": "string",
    "description": "模板不存在或渲染失败时的处理方式。",
    "options": [
      "跳过",
      "保留原样",
      "插入错误"
    ],
    "default": "跳过"
  },
  "default_block_template": {
    "type": "text",
    "description": "默认模板包裹格式，支持 $alias、$source_type 和 $content。",
    "default": "<context_template alias=\"$alias\" source=\"$source_type\">\n$content\n</context_template>"
  },
  "error_template": {
    "type": "text",
    "description": "当处理方式为“插入错误”时使用的错误模板，支持 $alias 和 $reason。",
    "default": "[上下文模板错误: $alias -> $reason]"
  },
  "default_max_chars": {
    "type": "int",
    "description": "文件模板或命令模板未单独设置限制时的默认最大字符数。",
    "default": 12000
  },
  "default_command_timeout_sec": {
    "type": "int",
    "description": "命令模板的默认超时时间（秒）。",
    "default": 10
  },
  "templates": {
    "type": "template_list",
    "description": "上下文模板列表。",
    "default": [],
    "templates": {
      "text": {
        "name": "文本模板",
        "items": {
          "enabled": {
            "type": "bool",
            "description": "是否启用该模板。",
            "default": true
          },
          "alias": {
            "type": "string",
            "description": "模板别名，可用于 append_aliases 或 {{ctx:alias}}。",
            "default": "note"
          },
          "block_template": {
            "type": "text",
            "description": "可选的单模板包裹格式，支持 $alias、$source_type 和 $content。",
            "default": ""
          },
          "content": {
            "type": "text",
            "description": "原始文本内容。",
            "default": ""
          }
        }
      },
      "file": {
        "name": "文件模板",
        "items": {
          "enabled": {
            "type": "bool",
            "description": "是否启用该模板。",
            "default": true
          },
          "alias": {
            "type": "string",
            "description": "模板别名，可用于 append_aliases 或 {{ctx:alias}}。",
            "default": "file_context"
          },
          "base_dir": {
            "type": "string",
            "description": "当路径为相对路径时，所使用的基准目录。",
            "options": [
              "技能目录",
              "数据目录",
              "插件数据目录",
              "根目录"
            ],
            "default": "插件数据目录"
          },
          "path": {
            "type": "string",
            "description": "绝对路径，或相对于基准目录的路径。",
            "default": "context.txt"
          },
          "max_chars": {
            "type": "int",
            "description": "可选的单模板输出上限。0 表示使用默认值。",
            "default": 0
          },
          "block_template": {
            "type": "text",
            "description": "可选的单模板包裹格式，支持 $alias、$source_type 和 $content。",
            "default": ""
          }
        }
      },
      "command": {
        "name": "命令模板",
        "items": {
          "enabled": {
            "type": "bool",
            "description": "是否启用该模板。",
            "default": true
          },
          "alias": {
            "type": "string",
            "description": "模板别名，可用于 append_aliases 或 {{ctx:alias}}。",
            "default": "git_status"
          },
          "command": {
            "type": "text",
            "description": "要执行的 Shell 命令。",
            "default": ""
          },
          "timeout_sec": {
            "type": "int",
            "description": "可选的单模板超时时间。0 表示使用默认值。",
            "default": 0
          },
          "workdir_base": {
            "type": "string",
            "description": "当工作目录为相对路径时，所使用的基准目录。",
            "options": [
              "根目录",
              "数据目录",
              "技能目录",
              "插件数据目录"
            ],
            "default": "根目录"
          },
          "workdir": {
            "type": "string",
            "description": "可选的工作目录。绝对路径必须位于 AstrBot 根目录相关范围内。",
            "default": ""
          },
          "max_chars": {
            "type": "int",
            "description": "可选的单模板输出上限。0 表示使用默认值。",
            "default": 0
          },
          "block_template": {
            "type": "text",
            "description": "可选的单模板包裹格式，支持 $alias、$source_type 和 $content。",
            "default": ""
          }
        }
      }
    }
  }
}
