{
  "enabled": {
    "type": "bool",
    "description": "启用插件",
    "default": true
  },
  "expand_prompt_placeholders": {
    "type": "bool",
    "description": "展开 {{ctx:alias}}",
    "default": true
  },
  "append_aliases": {
    "type": "list",
    "description": "自动注入的模板别名",
    "default": []
  },
  "append_separator": {
    "type": "text",
    "description": "自动注入分隔符",
    "default": "\n\n"
  },
  "missing_behavior": {
    "type": "string",
    "description": "模板失败时的处理方式",
    "options": [
      "跳过",
      "保留原样",
      "插入错误"
    ],
    "default": "跳过"
  },
  "default_block_template": {
    "type": "text",
    "description": "默认包裹格式 支持 $alias、$source_type、$content",
    "default": "<context_template alias=\"$alias\" source=\"$source_type\">\n$content\n</context_template>"
  },
  "error_template": {
    "type": "text",
    "description": "错误模板 支持 $alias、$reason",
    "default": "[上下文模板错误: $alias -> $reason]"
  },
  "default_max_chars": {
    "type": "int",
    "description": "默认最大字符数",
    "default": 12000
  },
  "default_command_timeout_sec": {
    "type": "int",
    "description": "默认命令超时（秒）",
    "default": 10
  },
  "templates": {
    "type": "template_list",
    "description": "模板列表",
    "default": [],
    "templates": {
      "text": {
        "name": "文本模板",
        "items": {
          "enabled": {
            "type": "bool",
            "description": "启用模板",
            "default": true
          },
          "alias": {
            "type": "string",
            "description": "模板别名",
            "default": "note"
          },
          "block_template": {
            "type": "text",
            "description": "单模板包裹格式",
            "default": ""
          },
          "content": {
            "type": "text",
            "description": "文本内容",
            "default": ""
          }
        }
      },
      "file": {
        "name": "文件模板",
        "items": {
          "enabled": {
            "type": "bool",
            "description": "启用模板",
            "default": true
          },
          "alias": {
            "type": "string",
            "description": "模板别名",
            "default": "file_context"
          },
          "base_dir": {
            "type": "string",
            "description": "相对路径基准目录",
            "options": [
              "技能目录",
              "数据目录",
              "插件数据目录",
              "根目录"
            ],
            "default": "插件数据目录"
          },
          "path": {
            "type": "string",
            "description": "文件路径",
            "default": "context.txt"
          },
          "max_chars": {
            "type": "int",
            "description": "字符上限 0 为默认",
            "default": 0
          },
          "block_template": {
            "type": "text",
            "description": "单模板包裹格式",
            "default": ""
          }
        }
      },
      "command": {
        "name": "命令模板",
        "items": {
          "enabled": {
            "type": "bool",
            "description": "启用模板",
            "default": true
          },
          "alias": {
            "type": "string",
            "description": "模板别名",
            "default": "git_status"
          },
          "executable": {
            "type": "string",
            "description": "程序名或可执行文件路径",
            "default": ""
          },
          "args": {
            "type": "list",
            "description": "参数列表",
            "default": []
          },
          "command": {
            "type": "text",
            "description": "命令行字符串 会自动拆分执行",
            "default": ""
          },
          "timeout_sec": {
            "type": "int",
            "description": "超时秒数 0 为默认",
            "default": 0
          },
          "workdir_base": {
            "type": "string",
            "description": "工作目录基准目录",
            "options": [
              "根目录",
              "数据目录",
              "技能目录",
              "插件数据目录"
            ],
            "default": "根目录"
          },
          "workdir": {
            "type": "string",
            "description": "工作目录",
            "default": ""
          },
          "max_chars": {
            "type": "int",
            "description": "字符上限 0 为默认",
            "default": 0
          },
          "block_template": {
            "type": "text",
            "description": "单模板包裹格式",
            "default": ""
          }
        }
      }
    }
  }
}
